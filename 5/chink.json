      "antonyms": []
    },
    {
      "partOfSpeech": "verb",
      "definitions": [
        {
          "definition": "To fill an opening such as the space between logs in a log house with chinking; to caulk.",
          "synonyms": [],
          "antonyms": [],
          "example": "to chink a wall"
        },
        {
          "definition": "To crack; to open.",
          "synonyms": [],
          "antonyms": []
        },
        {
